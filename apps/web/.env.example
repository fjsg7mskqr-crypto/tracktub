# Supabase — copy to .env.local and fill in (values from Project Settings → API).
# .env.local is gitignored. NEVER commit real keys; never paste service_role in chat.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Used by the RLS test suite to provision/tear down test data.
SUPABASE_SERVICE_ROLE_KEY=

# Rate limiting (issue #42) — OPTIONAL. Without these two vars, rate limiting is
# a no-op (every request allowed), so the app runs fine locally without them.
# To activate: create an Upstash Redis (https://upstash.com), then set both in
# Vercel for Preview + Production. Server-only; never NEXT_PUBLIC_*.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
