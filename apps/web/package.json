{
  "name": "tracktub-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "vercel-build": "next build && node scripts/link-next-at-monorepo-root.mjs",
    "start": "next start -p 3000",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rls": "vitest run tests/rls.test.ts",
    "promo:status": "bash ../../scripts/promo-status.sh"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.57.0",
    "@supabase/ssr": "0.12.0",
    "@supabase/supabase-js": "2.108.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "gray-matter": "^4.0.3",
    "next": "16.2.9",
    "posthog-js": "^1.386.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.2.9",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.10",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vitest": "4.1.8"
  }
}
